# XRXS_DEPARTMENTS_URL=
# XRXS_EMPLOYEES_URL=
# XRXS_APP_ID=
# XRXS_APP_SECRET=
# XRXS_COMPANY_ID=

NEXTCLOUD_DB_HOST=db
NEXTCLOUD_DB_PORT=3306
NEXTCLOUD_DB_NAME=nextcloud
NEXTCLOUD_DB_USER=nextcloud
NEXTCLOUD_DB_PASSWORD=
NEXTCLOUD_DEFAULT_GROUP=ALL
NEXTCLOUD_DEPARTMENT_GROUP_ALIASES=服务运营部=服务解决方案中心,项目管理部=服务解决方案中心,服务交付部=服务解决方案中心,服务创新与Marketing部=服务解决方案中心,交付组=服务解决方案中心,运维组=服务解决方案中心,东区作战平台=联合指挥作战中心,西区作战平台=联合指挥作战中心,中区作战平台=联合指挥作战中心,广东作战平台=联合指挥作战中心,上海作战平台=联合指挥作战中心,铁路先遣队=联合指挥作战中心,联指办公室=联合指挥作战中心,上海组=联合指挥作战中心,中区组=联合指挥作战中心,东区组=联合指挥作战中心,西区组=联合指挥作战中心,广东组=联合指挥作战中心

